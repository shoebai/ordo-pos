rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── /releases/ ────────────────────────────────────────
    // Anyone can download release files (they need the URL anyway).
    // Only admin can upload new releases.
    match /releases/{filename} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == "mwz0F01sufMu4AZ7OblEBmSLlgz1" // UID for yshoeb52@gmail.com;
    }

    // ── Deny everything else ──────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
